{{ define "authn_methods" }}

    <div id="authn-mode-switch-container">
      <div class="spacer-container">
        <div>{{ T . "identity.login.authn_methods.or" }}{{ if not .Data.IsForceAuthMode}} {{ T . "identity.login.authn_methods.log_in_with" }}{{ end }}</div>
      </div>

      <div class="form-field">
        {{ if .Data.AuthenticationMechanismsAvailability.password }}
          {{ if ne .Data.AuthnView "password_view" }}
              <button class="href-card" type="submit" name="action" value="change_to_password" id="login-option-password">
                <div>
                  <span class="href-card-avatar href-card-avatar-with-img small-icon">
                    <img src="{{ .Config.Assets }}/static/images/password-icon-2.svg" alt="password method image" />
                  </span>
                  <span>{{ T . "identity.login.authn_methods.password" }}</span>
                </div>
                <i class="material-icons">navigate_next</i>
              </button>
          {{ end }}
        {{ end }}

        {{ if .Data.AuthenticationMechanismsAvailability.otp }}
            {{ if and (ne .Data.AuthnView "otp_send_view") (ne .Data.AuthnView "otp_verify_view") (ne .Data.AuthnView "otp_use_alternative_view") }}
                <button class="href-card" type="submit" name="action" value="{{ if or .Data.IsForceAuthMode .Data.Is2FAStep (not (eq .Data.Identifier ""))}}send_otp{{ else }}change_to_otp{{ end }}" id="login-option-code" style="display: flex">
                    <div>
                        <span class="href-card-avatar href-card-avatar-with-img small-icon">
                            <img src="{{ .Config.Assets }}/static/images/otp-icon.svg" alt="verification code method image" />
                        </span>
                        <span>{{ T . "identity.login.authn_methods.verification_code" }}</span>
                    </div>
                    <i class="material-icons">navigate_next</i>
                </button>
            {{ end }}
        {{ end }}

        {{ if .Data.AuthenticationMechanismsAvailability.webauthn }}
          {{if ne .Data.AuthnView "web_authn_view" }}
              <button class="href-card" type="submit" name="action" value="change_to_web_authn" id="login-option-web-authn">
                <div>
                  <span class="href-card-avatar href-card-avatar-with-img small-icon">
                    <img src="{{ .Config.Assets }}/static/images/webauthn-icon.svg" alt="passkey method image" />
                  </span>
                  <span>{{ T . "identity.login.authn_methods.passkey" }}</span>
                </div>
                <i class="material-icons">navigate_next</i>
              </button>
          {{ end }}
        {{ end }}

        {{ if .Data.AuthenticationMechanismsAvailability.totp }}
          {{if ne .Data.AuthnView "totp_view" }}
              <button class="href-card" type="submit" name="action" value="change_to_totp" id="login-option-totp">
                <div>
                  <span class="href-card-avatar href-card-avatar-with-img small-icon">
                    <img src="{{ .Config.Assets }}/static/images/smartphone-icon.svg" alt="authenticator code method image" />
                  </span>
                  <span>{{ T . "identity.login.authn_methods.authenticator_code" }}</span>
                </div>
                <i class="material-icons">navigate_next</i>
              </button>
          {{ end }}
        {{ end }}

      </div>
    </div>

{{ end }}